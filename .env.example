## Supabase (server-side only)
# Create a Supabase project and copy these from Project Settings → API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

## App auth/session
# A long random string used to HMAC-sign cookies/tokens (generate your own).
AUTH_SECRET=

## Cookie settings (optional)
# Set to 1 in production behind HTTPS so cookies are marked secure.
AUTH_COOKIE_SECURE=0

